{
  "schemaVersion": 1,
  "id": "threed_model_now",
  "version": "${version}",
  "name": "3DModelNow",
  "description": "Standalone 3D player-model framework for Fabric 1.21.11. Format-specific importers and displays are supplied by optional addons.",
  "authors": [
    "3DModelNow contributors"
  ],
  "contributors": [
    "YS Group",
    "TartaricAcid",
    "TomatoPuddin",
    "AryochiL",
    "bernie-g (GeckoLib)",
    "fadookie (mclib)",
    "TT432 & SQwatermark",
    "OpenYSM/YSMParser",
    "OpenAI Codex implementation support"
  ],
  "contact": {
    "homepage": "https://github.com/Whyaremax"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.threedmodelnow.fabric1211.ThreeDModelNowMod"
    ],
    "client": [
      "com.threedmodelnow.fabric1211.ThreeDModelNowMod"
    ]
  },
  "mixins": [
    "threed_model_now.client.mixins.json"
  ],
  "depends": {
    "java": ">=21",
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}"
  },
  "breaks": {
    "iris": "<1.8.0"
  },
  "custom": {
    "loom:injected_interfaces": {}
  }
}
